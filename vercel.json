{
  "buildCommand": "python build_static.py",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/read/:id",
      "destination": "/reader.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}